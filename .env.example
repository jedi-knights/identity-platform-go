# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env

# ADR-0008: tokens are now signed with RS256 by default. auth-server generates
# a fresh in-memory keypair at startup; token-introspection-service and
# example-resource-service fetch the public keys from auth-server's JWKS
# endpoint (http://auth-server:8080/.well-known/jwks.json in docker-compose).
# No shared secret is required — the variable below is kept only for users
# who want to fall back to the legacy HS256 path by setting
# AUTH_JWT_SIGNING_ALG=HS256 (and the matching SIGNING_KEY env vars) on each
# service.
#
# For production RS256 deployments, set AUTH_JWT_RSA_PRIVATE_KEY_PEM to a
# PEM-encoded RSA private key (openssl genrsa -out key.pem 2048) so tokens
# survive restart.
#
# Legacy HS256 fallback (unused under the docker-compose defaults below):
#   - Minimum 32 characters
#   - Must not be "change-me-in-production" or "default-signing-key"
#   - Use a random value: openssl rand -hex 32
JWT_SIGNING_KEY=replace-this-with-a-random-value-at-least-32-chars  # pragma: allowlist secret

# Secret for the dev seed client seeded into auth-server on startup.
# The client id is "test-client". Use this secret when requesting tokens:
#
#   curl -s -X POST http://localhost:8080/oauth/token \
#     -d "grant_type=client_credentials" \
#     -d "client_id=test-client" \
#     -d "client_secret=<DEV_CLIENT_SECRET>" \
#     -d "scope=read"
DEV_CLIENT_SECRET=replace-this-with-a-dev-secret  # pragma: allowlist secret

# PostgreSQL password for all services. Must be at least 16 characters.
POSTGRES_PASSWORD=change-me-postgres-password  # pragma: allowlist secret

# Redis password. Must be at least 16 characters.
REDIS_PASSWORD=change-me-redis-password  # pragma: allowlist secret
